# ============================================================
# Marketing Dashboard - Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# --- Database (Supabase) ---
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.supabase.com:5432/postgres"

# --- Auth ---
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"
DASHBOARD_PASSWORD="your-secure-password"

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=""

# --- YouTube Data API v3 ---
YOUTUBE_API_KEY=""
YOUTUBE_CHANNEL_ID=""

# --- Instagram Graph API ---
INSTAGRAM_ACCESS_TOKEN=""
INSTAGRAM_USER_ID=""
META_APP_ID=""
META_APP_SECRET=""

# --- Kajabi ---
KAJABI_API_KEY=""
KAJABI_SITE_ID=""

# --- Nano Banana Pro ---
NANO_BANANA_API_KEY=""
NANO_BANANA_API_URL=""

# --- Cron Security ---
CRON_SECRET="generate-a-random-secret-here"
NEXT_PUBLIC_CRON_SECRET=""

# --- Encryption (for settings page API key storage) ---
ENCRYPTION_KEY="32-char-hex-string"
